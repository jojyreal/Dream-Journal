// ── Import Modal ─────────────────────────────────────────────────────────────
function ImportModal({ onImport, onClose }) {
  const [text, setText] = useState("");
  const [err, setErr] = useState(null);
  const [success, setSuccess] = useState(null);
  const textareaRef = useRef(null);

  const tryPasteFromClipboard = async () => {
    try {
      const pasted = await navigator.clipboard.readText();
      setText(pasted);
      setErr(null);
    } catch {
      setErr("Clipboard access denied — please long-press the box below and paste manually.");
      textareaRef.current?.focus();
    }
  };

  const doImport = () => {
    setErr(null);
    setSuccess(null);
    const raw = text.trim();
    if (!raw) { setErr("Nothing to import — paste your JSON first."); return; }
    try {
      const parsed = JSON.parse(raw);
      if (!Array.isArray(parsed)) throw new Error("Expected an array of dreams.");
      const valid = parsed.filter(d => d && typeof d.id === "string" && typeof d.date === "string" && typeof d.description === "string");
      if (!valid.length) throw new Error("No valid dream entries found.");
      onImport(valid);
      setSuccess(`${valid.length} dream${valid.length !== 1 ? "s" : ""} imported!`);
      setText("");
      setTimeout(onClose, 1400);
    } catch (e) {
      setErr(`Import failed: ${e?.message || e}`);
    }
  };

  return (
    <div onClick={e => e.target === e.currentTarget && onClose()}
      style={{ position:"fixed", inset:0, background:"rgba(2,0,14,0.92)", zIndex:110, display:"flex", flexDirection:"column", alignItems:"center", justifyContent:"flex-end" }}>
      <div style={{ width:"100%", maxWidth:600, background:"linear-gradient(160deg,#090618,#0d0820)", borderTopLeftRadius:20, borderTopRightRadius:20, padding:"20px 16px calc(20px + env(safe-area-inset-bottom,0px))", boxShadow:"0 -10px 40px rgba(0,0,0,0.5)" }}>

        <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:16 }}>
          <h2 style={{ margin:0, fontFamily:"'Cinzel',serif", fontSize:18, color:"#60a5fa" }}>IMPORT DREAMS</h2>
          <button onClick={onClose} style={{ background:"none", border:"none", color:"#6366f1", fontSize:28, cursor:"pointer", width:44, height:44, display:"flex", alignItems:"center", justifyContent:"center" }}>×</button>
        </div>

        <p style={{ color:"#9ca3af", fontSize:13, margin:"0 0 14px", lineHeight:1.5 }}>
          Paste your exported JSON below, then tap <strong style={{color:"#93c5fd"}}>Import</strong>. Existing dreams with the same ID will be updated; new ones will be added.
        </p>

        <button onClick={tryPasteFromClipboard}
          style={{ width:"100%", marginBottom:10, padding:"13px 10px", borderRadius:12, border:"1px solid rgba(96,165,250,0.5)", background:"rgba(96,165,250,0.18)", color:"#e2d9ff", fontSize:14, cursor:"pointer", fontFamily:"'Cinzel',serif", letterSpacing:1 }}>
          PASTE FROM CLIPBOARD
        </button>

        <textarea
          ref={textareaRef}
          value={text}
          onChange={e => { setText(e.target.value); setErr(null); setSuccess(null); }}
          placeholder='Or long-press here and paste your JSON…'
          rows={10}
          style={{ width:"100%", background:"rgba(0,0,0,0.5)", border:`1px solid ${err ? "rgba(248,113,113,0.5)" : "rgba(167,139,250,0.2)"}`, borderRadius:12, color:"#c4b5fd", fontSize:11, fontFamily:"monospace", padding:"12px", resize:"none", boxSizing:"border-box", lineHeight:1.5, marginBottom:12 }}
        />

        {err && <p style={{ color:"#f87171", fontSize:12, margin:"0 0 10px" }}>{err}</p>}
        {success && <p style={{ color:"#6ee7b7", fontSize:13, margin:"0 0 10px", fontFamily:"'Cinzel',serif" }}>✓ {success}</p>}

        <button onClick={doImport} disabled={!text.trim()}
          style={{ width:"100%", padding:"13px", borderRadius:12, border:"none", background: text.trim() ? "linear-gradient(135deg,#1d4ed8,#4f46e5)" : "rgba(30,30,60,0.5)", color: text.trim() ? "white" : "#4b5563", fontSize:14, cursor: text.trim() ? "pointer" : "default", fontFamily:"'Cinzel',serif", letterSpacing:1 }}>
          IMPORT
        </button>
      </div>
    </div>
  );
}

// ── Export Modal ─────────────────────────────────────────────────────────────
function ExportModal({ dreams, onClose }) {
  const data = JSON.stringify(dreams, null, 2);
  const [copied, setCopied] = useState(false);
  const [shareErr, setShareErr] = useState(null);
  const textareaRef = useRef(null);

  const copyToClipboard = async () => {
    try {
      if (navigator.clipboard?.writeText) {
        await navigator.clipboard.writeText(data);
      } else {
        // Fallback for WebViews without clipboard API
        const ta = textareaRef.current;
        ta.select();
        ta.setSelectionRange(0, 99999);
        document.execCommand("copy");
      }
      setCopied(true);
      setTimeout(() => setCopied(false), 2500);
    } catch {
      setShareErr("Copy failed — please long-press the text below and select all.");
    }
  };

  const tryNativeShare = async () => {
    setShareErr(null);
    const filename = `dreams_${todayISO()}.json`;

    // Try Capacitor Share plugin (requires @capacitor/share installed)
    try {
      const { Share } = await import("@capacitor/share");
      await Share.share({
        title: "Dream Journal Export",
        text: data,
        dialogTitle: "Share your dreams",
      });
      return;
    } catch {}

    // Try Web Share API with file
    if (navigator.share) {
      try {
        const file = new File([data], filename, { type: "application/json" });
        if (navigator.canShare?.({ files: [file] })) {
          await navigator.share({ files: [file], title: "Dream Journal Export" });
          return;
        }
        await navigator.share({ title: "Dream Journal Export", text: data });
        return;
      } catch (e) {
        if (e.name === "AbortError") return;
      }
    }

    setShareErr("Native share not available — use Copy above.");
  };

  return (
    <div onClick={e => e.target === e.currentTarget && onClose()}
      style={{ position:"fixed", inset:0, background:"rgba(2,0,14,0.92)", zIndex:110, display:"flex", flexDirection:"column", alignItems:"center", justifyContent:"flex-end" }}>
      <div style={{ width:"100%", maxWidth:600, background:"linear-gradient(160deg,#090618,#0d0820)", borderTopLeftRadius:20, borderTopRightRadius:20, padding:"20px 16px calc(20px + env(safe-area-inset-bottom,0px))", boxShadow:"0 -10px 40px rgba(0,0,0,0.5)" }}>

        <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:16 }}>
          <h2 style={{ margin:0, fontFamily:"'Cinzel',serif", fontSize:18, color:"#a78bfa" }}>EXPORT DREAMS</h2>
          <button onClick={onClose} style={{ background:"none", border:"none", color:"#6366f1", fontSize:28, cursor:"pointer", width:44, height:44, display:"flex", alignItems:"center", justifyContent:"center" }}>×</button>
        </div>

        <p style={{ color:"#9ca3af", fontSize:13, margin:"0 0 14px", lineHeight:1.5 }}>
          Your dream data as JSON. Tap <strong style={{color:"#c4b5fd"}}>Copy</strong> to copy it, then paste into a notes app, email, or file. Or tap <strong style={{color:"#c4b5fd"}}>Share</strong> to open the system share sheet.
        </p>

        <div style={{ display:"flex", gap:10, marginBottom:14 }}>
          <button onClick={copyToClipboard}
            style={{ flex:1, padding:"13px 10px", borderRadius:12, border:`1px solid ${copied ? "rgba(52,211,153,0.7)" : "rgba(99,102,241,0.6)"}`, background: copied ? "rgba(52,211,153,0.18)" : "rgba(99,102,241,0.25)", color: copied ? "#6ee7b7" : "#e2d9ff", fontSize:14, cursor:"pointer", fontFamily:"'Cinzel',serif", letterSpacing:1, transition:"all 0.2s" }}>
            {copied ? "✓ COPIED!" : "COPY"}
          </button>
          <button onClick={tryNativeShare}
            style={{ flex:1, padding:"13px 10px", borderRadius:12, border:"1px solid rgba(167,139,250,0.5)", background:"rgba(109,40,217,0.3)", color:"#e2d9ff", fontSize:14, cursor:"pointer", fontFamily:"'Cinzel',serif", letterSpacing:1 }}>
            SHARE ↗
          </button>
        </div>

        {shareErr && <p style={{ color:"#f87171", fontSize:12, margin:"0 0 10px" }}>{shareErr}</p>}

        <div style={{ position:"relative" }}>
          <div style={{ fontSize:11, color:"#6366f1", fontFamily:"'Cinzel',serif", letterSpacing:1, marginBottom:6 }}>
            {dreams.length} DREAM{dreams.length !== 1 ? "S" : ""} · {(new Blob([data]).size / 1024).toFixed(1)} KB
          </div>
          <textarea
            ref={textareaRef}
            readOnly
            value={data}
            rows={10}
            style={{ width:"100%", background:"rgba(0,0,0,0.5)", border:"1px solid rgba(167,139,250,0.2)", borderRadius:12, color:"#94a3b8", fontSize:11, fontFamily:"monospace", padding:"12px", resize:"none", boxSizing:"border-box", lineHeight:1.5 }}
          />
        </div>

        <p style={{ color:"#4b5563", fontSize:11, margin:"10px 0 0", textAlign:"center" }}>
          To import later, use the Import button on the journal screen.
        </p>
      </div>
    </div>
  );
}

// ── Main App ────────────────────────────────────────────────────────────────
export default function App() {
  const [dreams, setDreams] = useState(loadDreams);
  const [settings, setSettings] = useState(loadSettings);
  const [tab, setTab] = useState("journal");
  const [modal, setModal] = useState(false);
  const [editing, setEditing] = useState(null);
  const [search, setSearch] = useState("");
  const [panelScrollY, setPanelScrollY] = useState(0);
  const [exportOpen, setExportOpen] = useState(false);
  const [importOpen, setImportOpen] = useState(false);
  const appPanelRef = useRef(null);

  const handleImport = (valid) => {
    setDreams(current => {
      const existing = Object.fromEntries(current.map(d => [d.id, d]));
      valid.forEach(d => { existing[d.id] = d; });
      return Object.values(existing).sort((a,b) => b.date.localeCompare(a.date));
    });
  };

  useEffect(() => { saveDreams(dreams); }, [dreams]);
  useEffect(() => { saveSettings(settings); }, [settings]);

  useEffect(() => {
    const panel = appPanelRef.current;
    if (!panel) return;
    const onScroll = () => setPanelScrollY(panel.scrollTop);
    panel.addEventListener("scroll", onScroll, { passive: true });
    return () => panel.removeEventListener("scroll", onScroll);
  }, [appPanelRef]);

  const save = d => { setDreams(p=>p.find(x=>x.id===d.id)?p.map(x=>x.id===d.id?d:x):[d,...p]); setModal(false); setEditing(null); };
  const del = id => setDreams(p=>p.filter(d=>d.id!==id));
  const edit = d => { setEditing(d); setModal(true); };

  const filtered = dreams.filter(d=>{
    const q=search.toLowerCase();
    return !q||d.description?.toLowerCase().includes(q)||d.tags.some(t=>t.includes(q));
  }).sort((a,b)=>b.date.localeCompare(a.date));

  const tagSummary = TAGS.map(tag => ({
    ...tag,
    count: dreams.filter(d => d.tags.includes(tag.id)).length
  })).filter(tag => tag.count > 0);

  return (
    <div style={{height:"100vh", width:"100vw", background:"#02010d", color:"#e2d9ff", fontFamily:"'Lora',serif", position:"relative", overflow:"hidden"}}>
      <style>{`
        @import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Lora:ital,wght@0,400;0,500;1,400&display=swap');
        * { box-sizing: border-box; }
        html, body, #root { min-height: 100%; background: #02010d; margin: 0; }
        input, textarea, select, button { outline: none; font-size: 16px; }
        html, body { -webkit-text-size-adjust: 100%; -webkit-user-select: none; }
        body { touch-action: manipulation; }

        @media screen and (min-resolution: 440dpi) and (max-width: 420px) {
          .app-panel { max-width: 420px; width: 100vw; margin: 48px auto 0; padding: 26px 16px 16px; }
          .bottom-nav button, .fab, .tag-pill { min-height: 48px; }
          h1 { font-size: 28px !important; letter-spacing: 2px; }
          .dream-card p { font-size: 17px !important; }
        }

        @media (max-width: 430px) {
          .app-panel { max-width: 430px; width: 100vw; }
          .bottom-nav { padding-bottom: calc(14px + env(safe-area-inset-bottom, 8px)); }
          .search-row input { font-size: 17px; }
        }
        button, input, textarea, select { -webkit-tap-highlight-color: transparent; }
        button, .tag-pill, .nav-item, .fab { min-width: 44px; min-height: 44px; }
        button, .nav-item, .fab { user-select: none; }

        @media (max-width: 768px) {
          h1 { font-size: 24px; }
          .app-panel { padding: 14px !important; }
          .search-row { flex-direction: column !important; gap: 10px !important; }
          .search-row input { width: 100% !important; }
          .dream-card { padding: 12px !important; }
          .dream-modal-pane { max-width: 100% !important; padding: 16px !important; }
          .timeline-chart { height: 160px !important; }
        }
      `}</style>

      <div style={{position:"fixed", top:0, left:0, right:0, height:"env(safe-area-inset-top, 0px)", background:"#02010d", zIndex:99}} />
      <Starfield />

      <div ref={appPanelRef} className="app-panel" style={{position:"relative", zIndex:1, width:"100%", maxWidth:"100vw", margin:0, padding:"24px 16px 12px", height:"100vh", overflowY:"auto", overflowX:"hidden", overscrollBehavior:"contain", background:"linear-gradient(180deg, rgba(8,5,20,0.62), rgba(42,26,90,0.86) 40%, rgba(31,22,58,1))", backgroundAttachment:"fixed", backgroundPosition:`center ${Math.max(-panelScrollY*0.12, -80)}px`}}>
        <header style={{textAlign:"center", marginBottom:34, paddingTop:"calc(20px + env(safe-area-inset-top, 0px))"}}>
          <h1 style={{fontFamily:"'Cinzel',serif", fontSize:26, letterSpacing:2, margin:0, color:"#a78bfa"}}>Dream Journal</h1>
          <div style={{fontSize:14, color:"#c4b5fd", letterSpacing:1.5, marginTop:6}}>Quick notes, insights and sleep log</div>
        </header>

        {tab === "journal" && tagSummary.length > 0 && (
          <div style={{display:"flex", gap:8, overflowX:"auto", paddingBottom:12, marginBottom:12}}>
            {tagSummary.map(tag => (
              <div key={tag.id} className="tag-pill" style={{flex:"0 0 auto", background:`${tag.color}18`, border:`1px solid ${tag.color}45`, borderRadius:20, padding:"8px 12px", color:tag.color, fontSize:13, fontFamily:"'Cinzel',serif", minHeight:44, display:"flex", alignItems:"center", justifyContent:"center"}}>
                {tag.label} ({tag.count})
              </div>
            ))}
          </div>
        )}

        {tab === "journal" && (
          <>
            <div style={{display:"flex", gap:8, marginBottom:14, flexWrap:"wrap"}}>
              <button onClick={() => setExportOpen(true)} style={{flex:1, minWidth:120, background:"rgba(99,102,241,0.3)", border:"1px solid rgba(99,102,241,0.6)", borderRadius:10, color:"#e2d9ff", padding:"10px 12px", fontSize:13, cursor:"pointer"}}>Export Dreams</button>
              <button onClick={() => setImportOpen(true)} style={{flex:1, minWidth:120, background:"rgba(96,165,250,0.3)", border:"1px solid rgba(96,165,250,0.6)", borderRadius:10, color:"#e2d9ff", padding:"10px 12px", fontSize:13, cursor:"pointer"}}>Import Dreams</button>
            </div>
            <div className="search-row" style={{display:"flex", gap:10, marginBottom:16}}>
              <input value={search} onChange={e=>setSearch(e.target.value)} placeholder="Search..." style={{flex:1, background:"rgba(8,5,20,0.7)", border:"1px solid rgba(167,139,250,0.16)", borderRadius:10, color:"#e2d9ff", padding:"12px 14px", minHeight:44}} />
            </div>
            {filtered.length===0 ? <div style={{textAlign:"center", padding:70, color:"#6366f1", fontFamily:"'Cinzel',serif"}}>NO DREAMS FOUND</div> : filtered.map(d=><DreamCard key={d.id} dream={d} onEdit={edit} onDelete={del} />)}
          </>
        )}

        {tab === "stats" && <Stats dreams={dreams} onSelectDream={edit} />}
        {tab === "analysis" && <Analysis dreams={dreams} settings={settings} />}
        {tab === "settings" && <SettingsPage settings={settings} onSave={setSettings} />}
      </div>

      {tab === "journal" && (
        <button className="fab" onClick={()=>{setEditing(null);setModal(true);}} style={{position:"fixed", right:20, bottom:"calc(84px + env(safe-area-inset-bottom, 0px))", width:56, height:56, borderRadius:"50%", border:"none", background:"linear-gradient(135deg,#7c3aed,#4f46e5)", color:"white", fontSize:28, lineHeight:1, display:"flex", alignItems:"center", justifyContent:"center", boxShadow:"0 10px 20px rgba(15,10,35,0.35)", zIndex:95, cursor:"pointer"}}>+</button>
      )}

      <div className="bottom-nav" style={{position:"fixed", bottom:0, left:0, right:0, background:"rgba(8,5,20,0.96)", borderTop:"1px solid rgba(167,139,250,0.2)", padding:"8px calc(10px + env(safe-area-inset-left,0px)) calc(12px + env(safe-area-inset-bottom,8px)) calc(10px + env(safe-area-inset-right,0px))", display:"grid", gridTemplateColumns:"repeat(4,1fr)", zIndex:90}}>
        {[
          { id:"journal", label:"Journal" },
          { id:"stats", label:"Stats" },
          { id:"analysis", label:"Analysis" },
          { id:"settings", label:"Settings" }
        ].map(item => (
          <button key={item.id} className="nav-item" onClick={() => setTab(item.id)} style={{background:"none", border:"none", color: tab===item.id ? "#c4b5fd" : "#94a3b8", display:"flex", flexDirection:"column", alignItems:"center", justifyContent:"center", gap:2, fontSize:14, padding:"8px 4px", minHeight:44}}>
            <span style={{fontWeight:700}}>{item.label}</span>
          </button>
        ))}
      </div>

      {modal && <DreamModal dream={editing} onSave={save} onClose={()=>{setModal(false);setEditing(null);}} />}
      {exportOpen && <ExportModal dreams={dreams} onClose={() => setExportOpen(false)} />}
      {importOpen && <ImportModal onImport={handleImport} onClose={() => setImportOpen(false)} />}
    </div>
  );
}
